{
  "info": {
    "name": "Blacklist API - MISO DevOps",
    "description": "Colección de pruebas para el microservicio de lista negra global de emails",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "description": "URL base del servicio (cambiar por la URL de EB)"
    },
    {
      "key": "token",
      "value": "",
      "description": "JWT Bearer token generado con generate_token.py"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Service healthy', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('healthy');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/",
        "description": "Verifica que el servicio está activo"
      }
    },
    {
      "name": "POST /blacklists - Agregar email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 Created', function() {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Mensaje de confirmación', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.message).to.include('blacklist');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"spam@example.com\",\n  \"app_uuid\": \"uuid-app-test-001\",\n  \"blocked_reason\": \"Spam detectado en prueba de despliegue\"\n}"
        },
        "url": "{{base_url}}/blacklists",
        "description": "Agrega un email a la lista negra"
      }
    },
    {
      "name": "POST /blacklists - Sin autenticación (debe fallar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 Unauthorized', function() {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"app_uuid\": \"uuid-app-001\"\n}"
        },
        "url": "{{base_url}}/blacklists",
        "description": "Verifica que el endpoint requiere autenticación"
      }
    },
    {
      "name": "POST /blacklists - Email duplicado (debe fallar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 Bad Request', function() {",
              "    pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"spam@example.com\",\n  \"app_uuid\": \"uuid-app-test-001\"\n}"
        },
        "url": "{{base_url}}/blacklists",
        "description": "Intenta agregar el mismo email dos veces"
      }
    },
    {
      "name": "GET /blacklists/:email - Email bloqueado",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Email está bloqueado', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.is_blacklisted).to.eql(true);",
              "});",
              "pm.test('Tiene razón de bloqueo', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.blocked_reason).to.not.be.null;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/blacklists/spam@example.com",
        "description": "Consulta un email que está en la lista negra"
      }
    },
    {
      "name": "GET /blacklists/:email - Email no bloqueado",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Email no está bloqueado', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.is_blacklisted).to.eql(false);",
              "});",
              "pm.test('Sin razón de bloqueo', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.blocked_reason).to.be.null;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/blacklists/legit@example.com",
        "description": "Consulta un email que NO está en la lista negra"
      }
    },
    {
      "name": "GET /blacklists/:email - Sin autenticación (debe fallar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 Unauthorized', function() {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/blacklists/spam@example.com",
        "description": "Verifica que el endpoint GET también requiere autenticación"
      }
    }
  ]
}
