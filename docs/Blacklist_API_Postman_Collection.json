{
  "info": {
    "name": "Blacklist API - MISO DevOps",
    "description": "Colección de pruebas para el microservicio de lista negra global de emails.\n\nVariables requeridas:\n- base_url: URL del entorno EB (ej: http://Blacklist-env.xxx.elasticbeanstalk.com)\n- token: JWT Bearer token generado con `python generate_token.py`\n\nUso con Newman:\n  npx newman run Blacklist_API_Postman_Collection.json \\\n    --env-var \"base_url=http://<URL>\" \\\n    --env-var \"token=<TOKEN>\" \\\n    --iteration-count 20 --delay-request 8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "description": "URL base del servicio. En producción: URL del entorno Elastic Beanstalk"
    },
    {
      "key": "token",
      "value": "",
      "description": "JWT Bearer token. Generar con: $env:JWT_SECRET_KEY='<clave>' && python generate_token.py"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verifica que el servicio está activo y responde correctamente",
              "pm.test('Status 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Service healthy', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('healthy');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/",
        "description": "Endpoint de health check para AWS Elastic Beanstalk.\nNo requiere autenticación.\nRespuesta esperada: { status: 'healthy', service: 'blacklist-api' }"
      }
    },
    {
      "name": "POST /blacklists - Agregar email",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Genera un email único por iteración para evitar duplicados",
              "var timestamp = Date.now();",
              "pm.variables.set('email_test', 'spam_' + timestamp + '@example.com');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 Created', function() {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Mensaje de confirmación contiene blacklist', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.message).to.include('blacklist');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email_test}}\",\n  \"app_uuid\": \"uuid-app-test-001\",\n  \"blocked_reason\": \"Spam detectado en prueba de despliegue\"\n}"
        },
        "url": "{{base_url}}/blacklists",
        "description": "Agrega un email a la lista negra global.\nRequiere: Authorization Bearer token.\nEl email se genera dinámicamente por iteración (timestamp) para evitar duplicados.\nRespuesta esperada: 201 con mensaje de confirmación."
      }
    },
    {
      "name": "POST /blacklists - Sin autenticación (debe fallar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// El endpoint debe rechazar requests sin token",
              "pm.test('Status 401 Unauthorized', function() {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"app_uuid\": \"uuid-app-001\"\n}"
        },
        "url": "{{base_url}}/blacklists",
        "description": "Verifica que el endpoint POST requiere autenticación JWT.\nNo incluye header Authorization.\nRespuesta esperada: 401 Unauthorized."
      }
    },
    {
      "name": "POST /blacklists - Email duplicado (debe fallar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// El mismo email no puede agregarse dos veces",
              "pm.test('Status 400 Bad Request', function() {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('Mensaje indica que ya existe', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.message).to.include('already');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email_test}}\",\n  \"app_uuid\": \"uuid-app-test-001\"\n}"
        },
        "url": "{{base_url}}/blacklists",
        "description": "Intenta agregar el mismo email que se registró en el request anterior.\nUsa la misma variable {{email_test}} generada en el prerequest.\nRespuesta esperada: 400 Bad Request con mensaje de duplicado."
      }
    },
    {
      "name": "GET /blacklists/:email - Email bloqueado",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Email está bloqueado', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.is_blacklisted).to.eql(true);",
              "});",
              "pm.test('Tiene razón de bloqueo', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.blocked_reason).to.not.be.null;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/blacklists/{{email_test}}",
        "description": "Consulta si un email está en la lista negra.\nUsa {{email_test}} que fue agregado en el primer request de esta iteración.\nRespuesta esperada: 200 con is_blacklisted: true y blocked_reason no nulo."
      }
    },
    {
      "name": "GET /blacklists/:email - Email no bloqueado",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Email no está bloqueado', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.is_blacklisted).to.eql(false);",
              "});",
              "pm.test('Sin razón de bloqueo', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.blocked_reason).to.be.null;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/blacklists/legit@example.com",
        "description": "Consulta un email que nunca fue agregado a la lista negra.\nRespuesta esperada: 200 con is_blacklisted: false y blocked_reason: null."
      }
    },
    {
      "name": "GET /blacklists/:email - Sin autenticación (debe fallar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// El endpoint GET también debe requerir autenticación",
              "pm.test('Status 401 Unauthorized', function() {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/blacklists/legit@example.com",
        "description": "Verifica que el endpoint GET también requiere autenticación JWT.\nNo incluye header Authorization.\nRespuesta esperada: 401 Unauthorized."
      }
    }
  ]
}
