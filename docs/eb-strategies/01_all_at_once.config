# =============================================================================
# Estrategia: All-at-once
# Despliega en TODAS las instancias simultáneamente.
# Causa downtime breve pero es el más rápido.
# =============================================================================
# Para aplicar: copiar este archivo a .ebextensions/02_deployment.config
# O cambiar desde la consola: Configuration → Rolling updates and deployments

option_settings:
  aws:elasticbeanstalk:command:
    DeploymentPolicy: AllAtOnce
  aws:autoscaling:asg:
    MinSize: 3
    MaxSize: 6
  aws:elasticbeanstalk:environment:
    EnvironmentType: LoadBalanced
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /
