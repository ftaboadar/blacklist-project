# =============================================================================
# Blacklist API - Variables de entorno
# Copiar a .env y ajustar valores para entorno local
# =============================================================================

# PostgreSQL (RDS en producción)
RDS_HOSTNAME=localhost
RDS_PORT=5432
RDS_DB_NAME=blacklist_db
RDS_USERNAME=postgres
RDS_PASSWORD=postgres

# JWT - Cambiar en producción
JWT_SECRET_KEY=super-secret-key-devops-2024

# New Relic - Monitoreo continuo (Entrega 4)
# Obtener la license key en: one.newrelic.com -> (tu nombre) -> API Keys -> INGEST - LICENSE
NEW_RELIC_LICENSE_KEY=your_license_key_here
